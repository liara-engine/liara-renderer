PROJECT_NAME           = "liara-renderer"
PROJECT_ICON           = docs-shared/shared-content/assets/logo.svg
OUTPUT_DIRECTORY       = build/doxygen
INPUT                  = include/ README.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

OPTIMIZE_OUTPUT_FOR_C  = NO
BUILTIN_STL_SUPPORT    = YES

GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html

HTML_HEADER            = docs-shared/doxygen/header.html
HTML_FOOTER            = docs-shared/doxygen/footer.html
HTML_CODE_FOLDING      = YES

# Enable the side-nav tree (the Liara CSS is tuned for this layout)
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

# Disable Doxygen's own dark mode — we manage it via design tokens
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_MENUS     = YES

ALIASES += "threadsafety=<dl class='section threadsafety'><dt>Thread Safety</dt><dd>"
ALIASES += "endthreadsafety=</dd></dl>"
